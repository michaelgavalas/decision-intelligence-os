# Copy to .env and adjust. Never commit .env.
ENV=development
PORT=8080
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://dios:dios@localhost:5432/dios?sslmode=disable

# Auth - Ed25519 keys are PEM, base64, or hex encoded (generated at deploy time).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Cookies / CSRF
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
CSRF_SECRET=change-me-in-production

# CORS (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# GraphQL
GRAPHQL_INTROSPECTION=true
GRAPHQL_COMPLEXITY_LIMIT=300

# Optional AI features (disabled by default; product remains fully functional without them)
AI_ENABLED=false
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
